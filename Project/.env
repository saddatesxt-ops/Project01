# ==============================================================================
# SYSTEM - USTAWIENIA OGÓLNE
# ==============================================================================
SYSTEM_LOGS_DIR="logs"
SYSTEM_REVIEWS_DIR="reviews"
SYSTEM_USER_AGENT="Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36"

# ==============================================================================
# CENEO - KONFIGURACJA DLA SKRYPTU ceneo.py
# ==============================================================================
CENEO_PRODUCT_ID="181331617"
CENEO_BASE_URL="https://www.ceneo.pl"

# ==============================================================================
# MODELE LLM - KONFIGURACJA
# ==============================================================================
# 1. GOOGLE GEMINI
GEMINI_API_KEY="XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX"
GEMINI_MODEL_NAME="gemini-2.5-flash"

# Klucz do platformy Groq
GROQ_API_KEY="XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX"
# Lista modeli na Groq, które wspólnie przeanalizują recenzje
GROQ_MODELS_LIST="qwen/qwen3-32b,openai/gpt-oss-120b,llama-3.1-8b-instant"

# ==============================================================================
# MODELE LLM - INNE
# ==============================================================================
SYSTEM_USE_GROQ=True
SYSTEM_USE_GEMINI=True
SYSTEM_BATCH_SIZE=10

# ==============================================================================
# KONFIGURACJA POTOKU ENKODERÓW (HUGGING FACE / BERT)
# ==============================================================================
# 1. Modele Sentymentu
ENCODER_MODEL_SENTIMENT_LIST="Voicelab/herbert-base-cased-sentiment,nlptown/bert-base-multilingual-uncased-sentiment"

# 2. Modele Emocji
ENCODER_MODEL_EMOTION_LIST="visegradmedia-emotion/Emotion_RoBERTa_polish6,j-hartmann/emotion-english-distilroberta-base,yazoniak/twitter-emotion-pl-classifier,ayoubkirouane/BERT-Emotions-Classifier"

# Nazwa uniwersalnego modelu językowego spaCy
ENCODER_SPACY_MODEL="pl_core_news_md"

# Folder na modele wewnątrz katalogu uruchomieniowego (Project/models)
HF_HOME="models"
